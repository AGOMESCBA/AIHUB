# ============================================================
# IAHub — Configuracao de Ambiente
# Copie este arquivo para .env e preencha os valores abaixo
# ============================================================

# --- Inteligencia Artificial ---

# Chave da API do Groq (obtenha gratis em https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave da API do Google Gemini (fallback quando Groq atinge limite)
# Obtenha em https://aistudio.google.com
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Acesso ao Sistema ---

# Usuario e senha do administrador
ADMIN_USER=admin
ADMIN_PASS=iahub@2024

# Segredo para criptografia de sessao (mude para uma string aleatoria longa)
SESSION_SECRET=mude-para-uma-chave-secreta-aleatoria-longa

# --- Servidor ---

# Porta em que o Node.js vai rodar (padrao: 3000)
# PORT=3000

# Caminho do Chrome instalado (obrigatorio em Windows Server)
# O script 2-configurar-servico.ps1 adiciona esta linha automaticamente
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
